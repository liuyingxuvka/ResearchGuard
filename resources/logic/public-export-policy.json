{
  "schema_version": "skillguard.public_export_policy.v1",
  "blocked_extensions": [
    ".bak",
    ".db",
    ".key",
    ".log",
    ".p12",
    ".pem",
    ".sqlite",
    ".sqlite3"
  ],
  "blocked_names": [
    ".env",
    "credentials.json",
    "secrets.json"
  ],
  "runtime_path_prefixes": [
    ".skillguard/bootstrap/",
    ".skillguard/locks/",
    ".skillguard/runs/",
    ".skillguard/test-results/",
    "work/"
  ],
  "allowed_binary_extensions": [
    ".gif",
    ".ico",
    ".jpeg",
    ".jpg",
    ".png",
    ".webp"
  ],
  "visual_review_records": [
    {
      "asset_path": "assets/logicguard-viewer/logicguard-library-icon-64.png",
      "review_path": "assets/logicguard-viewer/visual-privacy-review-icon-64.json"
    },
    {
      "asset_path": "assets/logicguard-viewer/logicguard-library-icon-sidebar.png",
      "review_path": "assets/logicguard-viewer/visual-privacy-review-icon-sidebar.json"
    },
    {
      "asset_path": "assets/logicguard-viewer/logicguard-library-icon.png",
      "review_path": "assets/logicguard-viewer/visual-privacy-review-icon.json"
    },
    {
      "asset_path": "assets/logicguard-viewer/logicguard-library.ico",
      "review_path": "assets/logicguard-viewer/visual-privacy-review-ico.json"
    },
    {
      "asset_path": "assets/readme-hero/hero.png",
      "review_path": "assets/readme-hero/visual-privacy-review.json"
    },
    {
      "asset_path": "logicguard_viewer/assets/logicguard-library-icon-64.png",
      "review_path": "logicguard_viewer/assets/visual-privacy-review-icon-64.json"
    },
    {
      "asset_path": "logicguard_viewer/assets/logicguard-library-icon-sidebar.png",
      "review_path": "logicguard_viewer/assets/visual-privacy-review-icon-sidebar.json"
    },
    {
      "asset_path": "logicguard_viewer/assets/logicguard-library-icon.png",
      "review_path": "logicguard_viewer/assets/visual-privacy-review-icon.json"
    },
    {
      "asset_path": "logicguard_viewer/assets/logicguard-library.ico",
      "review_path": "logicguard_viewer/assets/visual-privacy-review-ico.json"
    }
  ],
  "claim_boundary": "This policy protects the public repository/export boundary. Runtime evidence remains local unless an explicitly sanitized release artifact is separately approved."
}
